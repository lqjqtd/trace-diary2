{
  "expo": {
    "name": "素履",
    "slug": "trace-diary",
    "version": "1.2.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F4F8"
    },
    "ios": {
      "bundleIdentifier": "com.trace_suo.diary",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "使用 Face ID 解锁素履",
        "NSPhotoLibraryUsageDescription": "允许素履访问相册以添加图片到日记"
      },
      "buildNumber": "10204"
    },
    "android": {
      "versionCode": 10204,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F4F8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.trace_suo.diary"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "使用 Face ID 解锁素履"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许素履访问相册以添加图片到日记"
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "允许素履访问位置以记录日记地点"
        }
      ],
      [
        "./plugins/withAMapLocation.js",
        {
          "apiKey": "b6207b5b2f71af9ed17f2394888ba571"
        }
      ],
      "expo-notifications",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "60ea3e3f-a8c4-446e-acb0-4c08aa7d3ff1"
      }
    },
    "owner": "duxjzb"
  }
}
